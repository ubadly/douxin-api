{
  "name": "douxin-api",
  "version": "1.0.0",
  "type": "module",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "tsx --test test/**/*.test.ts",
    "start": "fastify start -l info -c tsx app.ts",
    "dev": "fastify start -w -l info -P -c tsx app.ts",
    "build": "tsc --project tsconfig.json",
    "prod": "node dist/app.js"  
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/sensible": "^6.0.0",
    "crypto-js": "^4.2.0",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@fastify/autoload": "^6.0.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
